Bootstrap: docker
From: python:3.12.13-slim

%post
    pip install --no-cache-dir mlflow==3.10.1

%runscript
    mlflow server \
        --host 0.0.0.0 \
        --port 5000 \
        --backend-store-uri file:/app/mlruns \
        --default-artifact-root file:/app/mlruns \
        --allowed-hosts "*"